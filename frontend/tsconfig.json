{
    "extends": "@vue/tsconfig/tsconfig.dom.json",
    "include": ["env.d.ts", "src/**/*.ts", "src/**/*.vue"],
    "exclude": ["src/**/__tests__/*", "node_modules", "dist"],
    "compilerOptions": {
        "composite": true,
        "paths": {  
            "@/*": ["./src/*"]
        },
        "target": "ES2024",
        "lib": ["ES2024", "DOM", "DOM.Iterable"],
        "strict": true
    }
}